# Google Form ID (zorunlu) — viewform URL'sindeki /d/e/ ile /viewform arasındaki kısım
FORM_ID=your-google-form-id-here

# AI backend — en az biri zorunlu, öncelik sırası: Groq > Gemini > Anthropic
# Groq (önerilen, ücretsiz, hızlı): https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Gemini (ücretsiz tier var): https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Anthropic (ücretli, ücretsiz tier yok): https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here
